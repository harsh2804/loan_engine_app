# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Multi-Lender Loan Engine"
DEBUG=false
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:<db_password>@localhost:5432/loan_engine
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Anthropic Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<anthropic_api_key>
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_BATCH_SIZE=200

# ── Surepass ─────────────────────────────────────────────────────────────────
SUREPASS_BASE_URL=https://kyc-api.surepass.app
SUREPASS_AA_BASE_URL=https://kyc-api.surepass.app
SUREPASS_JWT_TOKEN=<surepass_jwt_token>
SUREPASS_MAX_RETRIES=1
SUREPASS_RETRY_BACKOFF=1.5

# ── AA Polling ────────────────────────────────────────────────────────────────
AA_POLL_INTERVAL_SECONDS=5
AA_POLL_MAX_ATTEMPTS=24
